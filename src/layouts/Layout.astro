---
import Footer from '@/components/footer.astro';
import MobileNav from '@/components/mobile-nav.astro';
import '../styles/global.css';

const {
  title = "Typpy – Typing Game for Brain",
  description = "Play Typpy, a fun typing game to prevent brain decline and improve speed, accuracy, and real-world typing skills.",
  url = "https://typpy.online",
  image = "https://typpy.online/og/default.png",
  type = "website",
  schema = null,
  keywords = '',
  genre = null,
  releaseDate = null,
  developer = null,
  publisher = null,
  platform = 'Web'
} = Astro.props;
---

<!DOCTYPE html>

<html class="light" lang="en"><head>
<meta charset="utf-8"/>
<meta content="width=device-width, initial-scale=1.0" name="viewport"/>
    <!-- Basic SEO -->
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={url} />

    <!-- OpenGraph -->
    <meta property="og:type" content={type} />
    <meta property="og:site_name" content="Typpy" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={url} />
    <meta property="og:image" content={image} />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:site" content="@typpy" />
    <meta name="twitter:creator" content="@typpy" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={image} />
    {keywords && <meta name="keywords" content={keywords} />}
    {genre && <meta name="genre" content={genre} />}
    {releaseDate && <meta property="article:published_time" content={releaseDate} />}
    {platform && <meta name="application-name" content={platform} />}
    {developer && <meta name="author" content={developer} />}
    {publisher && <meta name="publisher" content={publisher} />}
<link rel="icon" href="/favicon.svg" type="image/svg+xml">
<link rel="shortcut icon" href="/favicon.svg">
<!-- Fonts -->
<link href="https://fonts.googleapis.com" rel="preconnect"/>
<link crossorigin="" href="https://fonts.gstatic.com" rel="preconnect"/>
<link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800;900&amp;display=swap" rel="stylesheet"/>
<!-- Material Symbols -->
<link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap" rel="stylesheet"/>
<link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap" rel="stylesheet"/>
<!-- google adsense -->
<script async src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-9343510365156712"
     crossorigin="anonymous"></script>
     <!-- Google tag (gtag.js) -->
<script async src="https://www.googletagmanager.com/gtag/js?id=G-FKXKL01WVD"></script>
<script>
  window.dataLayer = window.dataLayer || [];
  function gtag(){dataLayer.push(arguments);}
  gtag('js', new Date());

  gtag('config', 'G-FKXKL01WVD');
</script>
<!-- Tailwind CSS compiled via the Tailwind Vite plugin (tailwind.config.cjs) -->
<style>
        .material-symbols-outlined {
            font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
        }
        /* Custom utilities for the typing area to ensure perfect rendering */
        .typing-text {
            word-spacing: 0.25em;
            letter-spacing: -0.01em;
        }
    </style>
    {schema && (
      <script type="application/ld+json">
{JSON.stringify(schema)}
      </script>
    )}
</head>
<body class="bg-background min-h-screen flex flex-col font-body text-body text-on-background selection:bg-brand-red selection:text-on-primary-container">
<!-- TopNavBar -->
<header class="sticky top-0 w-full z-50 bg-[#fcfcf9] dark:bg-[#1a1a18] border-b border-[#91918c]/20">
<div class="flex justify-between items-center h-16 px-8 w-full max-w-7xl mx-auto font-['Plus_Jakarta_Sans'] text-sm font-medium tracking-tight">
<!-- Brand -->
<a class="text-2xl font-black text-[#e60023] tracking-tighter" href="/"><img src="/logo.svg" alt="Typpy Logo" width="140""></a>
<!-- Navigation Links (Desktop) -->
<nav id="top-nav" class="hidden md:flex items-center gap-8">
    <a class="nav-link text-[#91918c] hover:text-[#33332e] dark:hover:text-[#fcfcf9] transition-colors pb-1 border-b-2 border-transparent" href="/mission">mission</a>
    <a class="nav-link text-[#91918c] hover:text-[#33332e] dark:hover:text-[#fcfcf9] transition-colors pb-1 border-b-2 border-transparent" href="/games">games</a>
    <a class="nav-link text-[#91918c] hover:text-[#33332e] dark:hover:text-[#fcfcf9] transition-colors pb-1 border-b-2 border-transparent" href="/faq">faq</a>
    <a class="nav-link text-[#91918c] hover:text-[#33332e] dark:hover:text-[#fcfcf9] transition-colors pb-1 border-b-2 border-transparent" href="/privacy">privacy</a>
</nav>
<!-- Mobile nav (mobile only) -->
<MobileNav />
<!-- Trailing Actions -->
<!-- <div class="flex items-center gap-4">
<button class="w-10 h-10 flex items-center justify-center text-[#91918c] hover:text-[#33332e] dark:hover:text-[#fcfcf9] hover:bg-[#e0e0d9] dark:hover:bg-[#33332e] rounded-full transition-all">
<span class="material-symbols-outlined" data-icon="settings">settings</span>
</button>
<button class="w-10 h-10 flex items-center justify-center text-[#91918c] hover:text-[#33332e] dark:hover:text-[#fcfcf9] hover:bg-[#e0e0d9] dark:hover:bg-[#33332e] rounded-full transition-all">
<span class="material-symbols-outlined" data-icon="person">person</span>
</button>
</div> -->
</div>
</header>
<script is:inline>
    (function () {
        const nav = document.getElementById('top-nav');
        if (!nav) return;
        const normalize = p => (p || '/').replace(/\/+$|^$/g, s => s === '' ? '/' : s).replace(/\/+$/, '') || '/';
        const currentPath = (location && location.pathname) ? (location.pathname.replace(/\/+$/, '') || '/') : '/';
        nav.querySelectorAll('a.nav-link').forEach(a => {
            const href = a.getAttribute('href') || '';
            const linkPath = (new URL(href, location.origin).pathname || '/').replace(/\/+$/, '') || '/';
            if (linkPath === currentPath) {
                a.classList.add('text-[#e60023]', 'border-[#e60023]');
                a.classList.remove('text-[#91918c]', 'border-transparent');
                a.setAttribute('aria-current', 'page');
            } else {
                a.classList.remove('text-[#e60023]', 'border-[#e60023]');
                a.classList.add('text-[#91918c]', 'border-transparent');
                a.removeAttribute('aria-current');
            }
        });
    })();
</script>
<slot />
<Footer />
</body>
</html>

