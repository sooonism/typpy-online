---
import Layout from '@/layouts/Layout.astro';
import GamePicker from '@/components/svelte/GamePicker.svelte';
---

<Layout>
	<!-- Main Game Canvas -->
<main class="flex-grow flex flex-col items-center justify-center py-section px-6 md:px-12 w-full max-w-6xl mx-auto">
	<GamePicker client:idle />
	</main>
</Layout>

<style>
	.home {
		min-height: 100vh;
		padding: 2rem 1.25rem;
		background:
			radial-gradient(circle at 20% 20%, #facc15 0%, transparent 30%),
			radial-gradient(circle at 80% 0%, #f97316 0%, transparent 40%),
			linear-gradient(160deg, #f8fafc 0%, #fff7ed 100%);
		color: #292524;
	}

	.hero,
	.links {
		max-width: 960px;
		margin: 0 auto;
	}

	.hero h1 {
		font-size: clamp(2rem, 6vw, 3rem);
		font-weight: 900;
		line-height: 1.05;
		letter-spacing: -0.04em;
		margin: 0.5rem 0 1rem;
	}

	.badge {
		display: inline-block;
		padding: 0.3rem 0.7rem;
		background: #292524;
		color: #ffedd5;
		border-radius: 999px;
		font-size: 0.8rem;
		font-weight: 700;
		letter-spacing: 0.05em;
		text-transform: uppercase;
	}

	.links {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
		gap: 1rem;
		margin-top: 2rem;
	}

	.card {
		display: block;
		padding: 1.2rem;
		border-radius: 16px;
		background: #fff;
		border: 2px solid #fdba74;
		text-decoration: none;
		color: inherit;
		box-shadow: 0 10px 30px -18px #c2410c;
		transition: transform 0.2s ease, box-shadow 0.2s ease;
	}

	.card:hover {
		transform: translateY(-2px);
		box-shadow: 0 18px 34px -18px #c2410c;
	}

	.card h2 {
		margin: 0 0 0.6rem;
	}

	.card p {
		margin: 0;
		opacity: 0.86;
	}
</style>
