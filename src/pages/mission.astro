---
import Layout from '@/layouts/Layout.astro';
---

<Layout>
    <main class="flex-grow flex flex-col items-center justify-center py-section px-6 md:px-12 w-full max-w-6xl mx-auto">
        <!-- Hero Section -->
    <header class="pt-[160px] pb-section px-md relative overflow-hidden">
        <div class="max-w-5xl mx-auto text-center relative z-10">
            <div class="inline-flex items-center gap-2 px-md py-xs mb-xl rounded-full bg-surface-container-high border border-outline-variant text-primary text-label-compact uppercase tracking-widest">
                <span class="material-symbols-outlined text-[16px]">target</span> The Typpy Mission
            </div>
            <h1 class="text-display-hero text-on-surface mb-xl">
                Make typing <span class="text-brand-red italic">addictive</span>,<br>
                meaningful, and effective.
            </h1>
            <p class="text-body text-on-surface-variant max-w-2xl mx-auto mb-xl">
                Typing is the core digital literacy of the 21st century. We're here to bridge the gap between rigid learning and shallow speed tests.
            </p>
            <div class="flex flex-wrap justify-center gap-md">
                <button class="bg-brand-red text-white px-xl py-md rounded-xl font-bold hover:scale-105 transition-all shadow-md">
                    Explore our vision
                </button>
                <div class="mono bg-sand-gray/50 px-xl py-md rounded-xl border border-outline flex items-center text-on-surface-variant">
                    <span>typpy --start-mission</span>
                    <span class="typing-cursor"></span>
                </div>
            </div>
        </div>
    </header>

                <!-- Research & vision -->
            <section class="mb-xl">
                <div class="flex items-center gap-2 mb-lg">
                    <span class="material-symbols-outlined text-brand-red">visibility</span>
                    <h2 class="text-2xl font-bold uppercase tracking-tight">The Vision</h2>
                </div>
                <div class="bg-brand-red p-xl rounded-[2rem] text-white">
                    <h3 class="text-xl font-bold mb-md">Why typing in 2026?</h3>
                    <p class="opacity-90 leading-relaxed mb-md">Even with voice and AI, text input remains the dominant mode of professional communication and creation. Coding, writing, and messaging all rely on the speed and precision of your fingers.</p>
                    <div class="flex flex-wrap gap-2">
                        <span class="bg-white/20 px-3 py-1 rounded-full text-xs font-bold">Cognitive Skill</span>
                        <span class="bg-white/20 px-3 py-1 rounded-full text-xs font-bold">Productivity Enhancer</span>
                        <span class="bg-white/20 px-3 py-1 rounded-full text-xs font-bold">Pattern Recognition</span>
                    </div>
                </div>
            </section>    
    <!-- Why Typpy Section -->
    <section id="mission" class="section-padding px-md bg-surface-container-low">
        <div class="max-w-7xl mx-auto">
            <div class="flex flex-col md:flex-row gap-xl items-start">
                <div class="md:w-1/3 sticky top-32">
                    <h2 class="text-section-heading text-on-surface mb-md uppercase tracking-tight">Why Typpy Exists</h2>
                    <p class="text-body text-on-surface-variant">
                        Professionals spend over <span class="text-brand-red font-bold">22 hours per week</span> typing. Most platforms today fail to reflect the reality of modern digital life.
                    </p>
                </div>
                
                <div class="md:w-2/3 space-y-md">
                    <!-- Point 1 -->
                    <div class="card-custom p-xl rounded-xl">
                        <div class="flex gap-lg">
                            <div class="text-primary text-section-heading mono opacity-50">01</div>
                            <div>
                                <h3 class="text-xl font-bold text-on-surface mb-sm">Typing is more than WPM</h3>
                                <p class="text-on-surface-variant mb-md">Research shows that looking at the keyboard can reduce performance to ~39.5 WPM versus ~61 WPM when relying on screen-based touch typing.</p>
                                <div class="flex flex-wrap gap-sm">
                                    <span class="bg-primary-fixed text-on-primary-fixed text-caption-bold px-md py-xs rounded-full">Flow State</span>
                                    <span class="bg-primary-fixed text-on-primary-fixed text-caption-bold px-md py-xs rounded-full">Accuracy</span>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Point 2 -->
                    <div class="card-custom p-xl rounded-xl">
                        <div class="flex gap-lg">
                            <div class="text-primary text-section-heading mono opacity-50">02</div>
                            <div>
                                <h3 class="text-xl font-bold text-on-surface mb-sm">Real-world Context</h3>
                                <p class="text-on-surface-variant mb-md">Common-word lists inflate scores. Typpy trains you for what you actually do: writing emails, debugging code, and drafting essays.</p>
                                <div class="flex flex-wrap gap-sm">
                                    <span class="bg-tertiary-fixed text-on-tertiary-fixed text-caption-bold px-md py-xs rounded-full">Adaptive AI</span>
                                    <span class="bg-tertiary-fixed text-on-tertiary-fixed text-caption-bold px-md py-xs rounded-full">Code Modes</span>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Point 3 -->
                    <div class="card-custom p-xl rounded-xl">
                        <div class="flex gap-lg">
                            <div class="text-primary text-section-heading mono opacity-50">03</div>
                            <div>
                                <h3 class="text-xl font-bold text-on-surface mb-sm">Targeted Feedback</h3>
                                <p class="text-on-surface-variant mb-md">Perfect practice makes perfect. We use weak-key detection to identify exactly which patterns are holding you back.</p>
                                <div class="flex flex-wrap gap-sm">
                                    <span class="bg-secondary-fixed text-on-secondary-fixed-variant text-caption-bold px-md py-xs rounded-full">Weak-key Analysis</span>
                                    <span class="bg-secondary-fixed text-on-secondary-fixed-variant text-caption-bold px-md py-xs rounded-full">Progression</span>
                                </div>
                            </div>
                        </div>
                        </div>

                    <!-- Fun Brain Vision Section -->
                    <section class="section-padding px-md bg-brand-red text-white overflow-hidden relative">
                        <div class="absolute top-0 right-0 p-xl opacity-10">
                            <span class="material-symbols-outlined text-[200px]">psychology_alt</span>
                        </div>
                        <div class="max-w-4xl mx-auto text-center relative z-10">
                            <h2 class="text-section-heading text-white mb-xl text-4xl">Level Up Your Brain, Not Just Your Speed</h2>
                            <p class="text-xl text-on-primary-container opacity-90 leading-relaxed mb-xl">
                                Typing with Typpy is like a gym session for your mind—every keystroke is a rep for your neurons! We turn typing into a fun, brain-boosting adventure that keeps your mind sharp and fends off the dreaded brain rot. Forget doom scrolling—let's build cognitive superpowers, one playful challenge at a time.
                            </p>
                            <div class="grid grid-cols-2 md:grid-cols-4 gap-md mb-xl">
                                <div class="bg-white/10 backdrop-blur p-lg rounded-xl border border-white/20">
                                    <span class="material-symbols-outlined mb-sm">sports_esports</span>
                                    <div class="text-caption-bold uppercase tracking-wider">Game Your Brain</div>
                                </div>
                                <div class="bg-white/10 backdrop-blur p-lg rounded-xl border border-white/20">
                                    <span class="material-symbols-outlined mb-sm">auto_awesome</span>
                                    <div class="text-caption-bold uppercase tracking-wider">Cognitive Quests</div>
                                </div>
                                <div class="bg-white/10 backdrop-blur p-lg rounded-xl border border-white/20">
                                    <span class="material-symbols-outlined mb-sm">psychology</span>
                                    <div class="text-caption-bold uppercase tracking-wider">Brain Rot Shield</div>
                                </div>
                                <div class="bg-white/10 backdrop-blur p-lg rounded-xl border border-white/20">
                                    <span class="material-symbols-outlined mb-sm">emoji_events</span>
                                    <div class="text-caption-bold uppercase tracking-wider">Fun First</div>
                                </div>
                            </div>
                            <button class="bg-white text-brand-red px-xl py-md rounded-2xl font-black text-lg hover:scale-105 transition-transform shadow-2xl">
                                JOIN THE TYPING GYM
                            </button>
                        </div>
                    </section>
                </div>
            </div>
        </div>
    </section>

    <!-- Philosophy -->
    <section class="section-padding px-md bg-background">
        <div class="max-w-7xl mx-auto">
            <h2 class="text-section-heading text-center text-on-surface mb-xl">The Typpy Philosophy</h2>
            <div class="grid md:grid-cols-3 gap-xl">
                <div class="text-center p-lg rounded-2xl bg-surface-container-low">
                    <div class="w-16 h-16 bg-primary-fixed rounded-2xl flex items-center justify-center mx-auto mb-lg text-primary">
                        <span class="material-symbols-outlined text-[32px]">sentiment_very_satisfied</span>
                    </div>
                    <h4 class="text-xl font-bold text-on-surface mb-sm">Fun Drives Consistency</h4>
                    <p class="text-on-surface-variant">If it feels like a game, you practice longer. Consistency is the predictor of improvement.</p>
                </div>
                <div class="text-center p-lg rounded-2xl bg-surface-container-low">
                    <div class="w-16 h-16 bg-tertiary-fixed rounded-2xl flex items-center justify-center mx-auto mb-lg text-tertiary">
                        <span class="material-symbols-outlined text-[32px]">psychology</span>
                    </div>
                    <h4 class="text-xl font-bold text-on-surface mb-sm">Smart over Repetition</h4>
                    <p class="text-on-surface-variant">Typing faster isn't about moving fingers faster—it's about building cognitive patterns.</p>
                </div>
                <div class="text-center p-lg rounded-2xl bg-surface-container-low">
                    <div class="w-16 h-16 bg-surface-container-highest rounded-2xl flex items-center justify-center mx-auto mb-lg text-primary">
                        <span class="material-symbols-outlined text-[32px]">verified</span>
                    </div>
                    <h4 class="text-xl font-bold text-on-surface mb-sm">Real Skills, Real Content</h4>
                    <p class="text-on-surface-variant">Typing random words is not the same as real content. We train for real-world fluency.</p>
                </div>
            </div>
        </div>
    </section>

    <!-- Vision Section -->
    <!-- <section id="vision" class="section-padding px-md bg-brand-red text-white overflow-hidden relative">
        <div class="absolute top-0 right-0 p-xl opacity-10">
            <span class="material-symbols-outlined text-[200px]">keyboard</span>
        </div>
        <div class="max-w-4xl mx-auto text-center relative z-10">
            <h2 class="text-section-heading text-white mb-xl text-4xl">The Duolingo of Typing</h2>
            <p class="text-xl text-on-primary-container opacity-90 leading-relaxed mb-xl">
                We believe typing platforms should evolve into cognitive training systems, productivity tools, and skill verification platforms.
            </p>
            
            <div class="grid grid-cols-2 md:grid-cols-4 gap-md mb-xl">
                <div class="bg-white/10 backdrop-blur p-lg rounded-xl border border-white/20">
                    <span class="material-symbols-outlined mb-sm">joystick</span>
                    <div class="text-caption-bold uppercase tracking-wider">Game Mechanics</div>
                </div>
                <div class="bg-white/10 backdrop-blur p-lg rounded-xl border border-white/20">
                    <span class="material-symbols-outlined mb-sm">auto_awesome</span>
                    <div class="text-caption-bold uppercase tracking-wider">Adaptive AI</div>
                </div>
                <div class="bg-white/10 backdrop-blur p-lg rounded-xl border border-white/20">
                    <span class="material-symbols-outlined mb-sm">monitoring</span>
                    <div class="text-caption-bold uppercase tracking-wider">Deep Analytics</div>
                </div>
                <div class="bg-white/10 backdrop-blur p-lg rounded-xl border border-white/20">
                    <span class="material-symbols-outlined mb-sm">groups</span>
                    <div class="text-caption-bold uppercase tracking-wider">Social Comp</div>
                </div>
            </div>

            <button class="bg-white text-brand-red px-xl py-md rounded-2xl font-black text-lg hover:scale-105 transition-transform shadow-2xl">
                JOIN THE BETA
            </button>
        </div>
    </section> -->
</main>
</Layout>

<style>
        .material-symbols-outlined {
            font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
            vertical-align: middle;
        }
        body {
            font-family: 'Plus Jakarta Sans', sans-serif;
            background-color: #fff8f7; /* background token */
            color: #2a1615; /* on-surface token */
            scroll-behavior: smooth;
        }
        .mono {
            font-family: 'JetBrains+Mono', monospace;
        }
        .typing-cursor {
            display: inline-block;
            width: 12px;
            height: 24px;
            background-color: #e60023; /* brand-red */
            animation: blink 1s infinite;
            vertical-align: middle;
            margin-left: 4px;
        }
        @keyframes blink {
            0%, 100% { opacity: 1; }
            50% { opacity: 0; }
        }
        .card-custom {
            background: #ffffff;
            border: 1px solid #e8bcb8; /* outline-variant */
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        }
        .card-custom:hover {
            border-color: #e60023;
            transform: translateY(-4px);
            box-shadow: 0 10px 30px -10px rgba(183, 0, 26, 0.1);
        }
        .section-padding {
            padding-top: 80px; /* section spacing token */
            padding-bottom: 80px;
        }
    </style>