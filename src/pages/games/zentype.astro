---
import Layout from '@/layouts/Layout.astro';
import Zentype from '@/components/svelte/games/zentype.svelte';

const title = 'ZenType — Typpy';
const description = 'ZenType: calm typing practice to improve speed and accuracy.';
const url = 'https://typpy.online/games/zentype';
const image = 'https://typpy.online/games/zentype.svg';
const keywords = 'typing, practice, zen, speed, accuracy, typing game';
const genre = 'Educational';
const releaseDate = '2026-04-26';
const developer = 'Typpy';
const publisher = 'Typpy';
const platform = 'Web';

const schema = [
  {
    "@context": "https://schema.org",
    "@type": "VideoGame",
    "name": title,
    "description": description,
    "url": url,
    "image": image,
    "brand": { "@type": "Brand", "name": "Typpy", "description": "Typpy — happy typing" },
    "applicationCategory": "Typing Game",
    "operatingSystem": "Web",
    "author": { "@type": "Organization", "name": "Typpy" },
    "publisher": { "@type": "Organization", "name": "Typpy" },
    "genre": "Educational",
    "datePublished": releaseDate
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://typpy.online" },
      { "@type": "ListItem", "position": 2, "name": "Games", "item": "https://typpy.online/games" },
      { "@type": "ListItem", "position": 3, "name": "ZenType", "item": "https://typpy.online/games/zentype" }
    ]
  }
];
---

<Layout title={title} description={description} url={url} image={image} keywords={keywords} genre={genre} releaseDate={releaseDate} developer={developer} publisher={publisher} platform={platform} schema={schema}>
  <Zentype client:only="svelte" />
</Layout>
