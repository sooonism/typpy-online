---
import Layout from '@/layouts/Layout.astro';
import Typerush from '@/components/svelte/games/typerush.svelte';

const title = 'Type Rush — Typpy';
const description = 'Type Rush: a fast arcade typing challenge with collectible diamonds. Typpy is typping game for brain.';
const url = 'https://typpy.online/games/type-rush';
const image = 'https://typpy.online/games/type-rush.svg';
const keywords = 'type, rush, typing, arcade, speed, diamonds, typing game, brain training';
const genre = 'Arcade';
const releaseDate = '2026-04-27';
const developer = 'Typpy';
const publisher = 'Typpy';
const platform = 'Web';

const schema = [
  {
    "@context": "https://schema.org",
    "@type": "VideoGame",
    "name": title,
    "description": description,
    "url": url,
    "image": image,
    "brand": { "@type": "Brand", "name": "Typpy", "description": "Typpy is typping game for brain" },
    "applicationCategory": "Arcade Typing Game",
    "operatingSystem": "Web",
    "author": { "@type": "Organization", "name": "Typpy" },
    "publisher": { "@type": "Organization", "name": "Typpy" },
    "genre": genre,
    "datePublished": releaseDate
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://typpy.online" },
      { "@type": "ListItem", "position": 2, "name": "Games", "item": "https://typpy.online/games" },
      { "@type": "ListItem", "position": 3, "name": "Type Rush", "item": "https://typpy.online/games/type-rush" }
    ]
  }
];
---

<Layout title={title} description={description} url={url} image={image} keywords={keywords} genre={genre} releaseDate={releaseDate} developer={developer} publisher={publisher} platform={platform} schema={schema}>
  <Typerush client:only="svelte" />
</Layout>
