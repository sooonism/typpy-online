---
import Layout from '@/layouts/Layout.astro';
import ZentypeReverse from '@/components/svelte/games/zentypereverse.svelte';

const title = 'ZenType Reverse — Typpy';
const description = 'ZenType Reverse: type backwards to train focus, accuracy, and mental agility. Typpy — happy typing.';
const url = 'https://typpy.online/games/zentype-reverse';
const image = 'https://typpy.online/games/zentype-reverse.svg';
const keywords = 'zen, typing, reverse, focus, accuracy, brain training, typing game';
const genre = 'Educational';
const releaseDate = '2026-04-27';
const developer = 'Typpy';
const publisher = 'Typpy';
const platform = 'Web';

const schema = [
  {
    "@context": "https://schema.org",
    "@type": "VideoGame",
    "name": title,
    "description": description,
    "url": url,
    "image": image,
    "brand": { "@type": "Brand", "name": "Typpy", "description": "Typpy — happy typing" },
    "applicationCategory": "Educational Typing Game",
    "operatingSystem": "Web",
    "author": { "@type": "Organization", "name": "Typpy" },
    "publisher": { "@type": "Organization", "name": "Typpy" },
    "genre": genre,
    "datePublished": releaseDate
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://typpy.online" },
      { "@type": "ListItem", "position": 2, "name": "Games", "item": "https://typpy.online/games" },
      { "@type": "ListItem", "position": 3, "name": "ZenType Reverse", "item": "https://typpy.online/games/zentype-reverse" }
    ]
  }
];
---

<Layout title={title} description={description} url={url} image={image} keywords={keywords} genre={genre} releaseDate={releaseDate} developer={developer} publisher={publisher} platform={platform} schema={schema}>
  <ZentypeReverse client:only="svelte" />
</Layout>
